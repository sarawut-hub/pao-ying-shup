      <div class="form-group" style="margin-bottom: 35px;">
        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Avatar Seed (Type anything to
          change look)</label>
        <input type="text" name="avatarSeed" id="seed-input" value="{{ user.avatarSeed || '' }}"
          placeholder="Try your name or lucky number">
        @inputError('avatarSeed')
        <p style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ $messages.join(', ') }}</p>
        @end
      </div>

      <button type="submit" class="btn" style="width: 100%; padding: 16px;">Save Changes</button>
    </form>
