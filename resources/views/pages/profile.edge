        style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden; border: 4px solid var(--primary); padding: 0; background: rgba(255,255,255,0.1);">
        <img id="avatar-preview"
          src="https://api.dicebear.com/7.x/{{ user.avatarStyle || 'fun-emoji' }}/svg?seed={{ user.avatarSeed || user.id }}"
