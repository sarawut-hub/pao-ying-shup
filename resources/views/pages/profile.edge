    <form action="{{ route('profile.update') }}" method="POST">
      {{ csrfField() }}

      <div class="form-group" style="margin-bottom: 25px;">
        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Display Name</label>
        <input type="text" name="fullName" value="{{ user.fullName || '' }}" required>
        @inputError('fullName')
        <p style="color: #ef4444; font-size: 12px; margin-top: 5px;">{{ $messages.join(', ') }}</p>
        @end
      </div>

      <div class="form-group" style="margin-bottom: 25px;">
        <label style="display: block; margin-bottom: 8px; color: var(--text-muted);">Avatar Style</label>
        <select name="avatarStyle" id="style-select"
          style="width: 100%; padding: 12px; background: #1e293b; border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; color: white; cursor: pointer;">
          <option value="adventurer" style="background: #1e293b;" {{ user.avatarStyle==='adventurer' ? 'selected' : ''
            }}>Adventurer (Serious Character)</option>
          <option value="personas" style="background: #1e293b;" {{ user.avatarStyle==='personas' ? 'selected' : '' }}>
            Personas (Clean & Real)</option>
          <option value="open-peeps" style="background: #1e293b;" {{ user.avatarStyle==='open-peeps' ? 'selected' : ''
            }}>Open Peeps (Hand-drawn Realism)</option>
          <option value="notionists" style="background: #1e293b;" {{ user.avatarStyle==='notionists' ? 'selected' : ''
            }}>Notionists (Modern Pro)</option>
          <option value="avataaars" style="background: #1e293b;" {{ user.avatarStyle==='avataaars' ? 'selected' : '' }}>
            Avataaars (Human-like)</option>
          <option value="fun-emoji" style="background: #1e293b;" {{ user.avatarStyle==='fun-emoji' ? 'selected' : '' }}>
